require_once("../config_api.php");

// 1. LÓGICA DE GRAVAÇÃO/EDIÇÃO (POST)
if ($_SERVER["REQUEST_METHOD"] === "POST") {
    header("Content-Type: application/json; charset=UTF-8");
    
    $nome       = trim($_POST['nome'] ?? '');
    $nif        = trim($_POST['nif'] ?? '');
    $telefone   = trim($_POST['telefone'] ?? '');
    $email      = trim($_POST['email'] ?? '');
    $endereco   = trim($_POST['endereco'] ?? '');
    $categoria  = trim($_POST['categoria'] ?? 'Geral');
    $pagamento  = trim($_POST['pagamento'] ?? '');

    if (empty($nome) || empty($nif)) {
        echo json_encode(["success" => false, "message" => "Nome e NIF são obrigatórios."]);
        exit;
    }

    try {
        $sql = "INSERT INTO fornecedores (nome, nif, telefone, email, endereco, categoria, condicoes_pagamento) 
                VALUES (?, ?, ?, ?, ?, ?, ?)";
        $stmt = $conn->prepare($sql);
        $stmt->bind_param("sssssss", $nome, $nif, $telefone, $email, $endereco, $categoria, $pagamento);
        
        if ($stmt->execute()) {
            echo json_encode(["success" => true, "message" => "Fornecedor cadastrado com sucesso.", "id" => $stmt->insert_id]);
        } else {
            throw new Exception("Erro ao salvar no banco de dados.");
        }
        $stmt->close();
    } catch (Exception $e) {
        echo json_encode(["success" => false, "message" => $e->getMessage()]);
    }
    $conn->close();
    exit;
}

// 2. LÓGICA DE BUSCA (GET) 
// Simulando a busca de um fornecedor específico (Ex: ID 7 do seu HTML) ou lista
$id_fornecedor = isset($_GET['id']) ? intval($_GET['id']) : 7; 

// Query para os dados do fornecedor
$sql_forn = "SELECT * FROM fornecedores WHERE id_fornecedor = $id_fornecedor";
$res_forn = $conn->query($sql_forn);
$fornecedor = ($res_forn && $res_forn->num_rows > 0) ? $res_forn->fetch_assoc() : null;

// Query para os últimos pedidos deste fornecedor
$sql_pedidos = "SELECT * FROM pedidos_compra WHERE id_fornecedor = $id_fornecedor ORDER BY data_pedido DESC LIMIT 5";
$res_pedidos = $conn->query($sql_pedidos);

